# STEP 2: Build the Feature Matrix

# CountVectorizer converts genre strings into a matrix
# where each column = one genre, each row = one movie
# A value of 1 means the movie has that genre, 0 means it doesn't

cv = CountVectorizer()
genre_matrix = cv.fit_transform(df['genres'])

print(f"🎭 Total unique genres found: {len(cv.get_feature_names_out())}")
print(f"📊 Genre feature matrix shape: {genre_matrix.shape}")
print(f"   (rows = movies, columns = genres)\n")



# STEP 3: Compute Cosine Similarity

# Cosine similarity measures the angle between two vectors
# Score of 1.0 = identical genres, 0.0 = completely different

similarity_matrix = cosine_similarity(genre_matrix)

print("✅ Cosine similarity matrix computed!")
print(f"   Matrix shape: {similarity_matrix.shape}\n")



# STEP 4: Recommendation Function


def recommend_movies(movie_title, num_recommendations=5):
    """
    Returns top N similar movies for a given movie title.

    Parameters:
    -----------
    movie_title : str
        Name of the movie to base recommendations on
    num_recommendations : int
        Number of similar movies to return (default = 5)

    Returns:
    --------
    DataFrame with recommended movies and similarity scores
    """

    # Find the movie in our dataset (case-insensitive)
    matches = df[df['title'].str.lower() == movie_title.strip().lower()]

    if matches.empty:
        print(f"❌ Movie '{movie_title}' not found in dataset.")
        print("   Try one of these:", ', '.join(df['title'].tolist()[:5]), "...")
        return None

    # Get the index of the input movie
    movie_index = matches.index[0]

    # Get similarity scores for this movie vs all others
    similarity_scores = list(enumerate(similarity_matrix[movie_index]))

    # Sort by similarity score (highest first), exclude the movie itself
    similarity_scores = sorted(similarity_scores, key=lambda x: x[1], reverse=True)
    similarity_scores = [(i, score) for i, score in similarity_scores if i != movie_index]

    # Pick top N recommendations
    top_movies = similarity_scores[:num_recommendations]

    # Build results DataFrame
    results = pd.DataFrame({
        'Rank': range(1, num_recommendations + 1),
        'Movie Title': [df.iloc[i]['title'] for i, _ in top_movies],
        'Genres': [df.iloc[i]['genres'] for i, _ in top_movies],
        'Similarity Score': [round(score, 4) for _, score in top_movies]
    })

    results = results.set_index('Rank')
    return results



# STEP 5: Run the Recommender

def run_recommender():
    """Interactive loop to get movie recommendations."""

    print("─" * 55)
    print("  MOVIE RECOMMENDER — Enter a movie to get suggestions")
    print("─" * 55)

    while True:
        print("\nAvailable movies (sample):")
        for i, title in enumerate(df['title'].tolist()):
            print(f"  {i+1:2}. {title}")

        print("\n" + "─" * 55)
        movie_name = input("\n🎬 Enter movie name (or 'quit' to exit): ").strip()

        if movie_name.lower() in ['quit', 'exit', 'q']:
            print("\n👋 Thanks for using Movie Recommender! Goodbye.\n")
            break

        if not movie_name:
            print("⚠️  Please enter a movie name.")
            continue

        print(f"\n🔍 Finding movies similar to: '{movie_name}'...\n")
        recommendations = recommend_movies(movie_name, num_recommendations=5)

        if recommendations is not None:
            input_movie = df[df['title'].str.lower() == movie_name.lower()].iloc[0]
            print(f"🎥 Input Movie : {input_movie['title']}")
            print(f"🎭 Genres      : {input_movie['genres']}")
            print("\n📽️  Top 5 Recommended Movies:")
            print("─" * 55)
            print(recommendations.to_string())
            print("─" * 55)

        print("\nWant another recommendation? (Press Enter to continue)")
        again = input()
        if again.lower() in ['no', 'n', 'quit', 'exit']:
            print("\n👋 Thanks for using Movie Recommender! Goodbye.\n")
            break



